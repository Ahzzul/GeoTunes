<Window x:Class="GeoTunes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeoTunes"
        mc:Ignorable="d"
        Title="GeoTunes" Height="450" Width="800">
    <Grid>
        <Label Content="Closest Cities" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Label Name="LBLCurrentPos" Content="Current Pos: " Margin="200,10" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <ListBox Name="LBClosestCities" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" Width="400" Height="360"/>
        <Button Content="Debug" HorizontalAlignment="Left" Margin="136,16,0,0" VerticalAlignment="Top" Click="Debug"/>
    </Grid>
</Window>
